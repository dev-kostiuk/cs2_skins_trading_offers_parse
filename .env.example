# ── DMarket offers ────────────────────────────────────────────
DMARKET_API_BASE=https://api.dmarket.com
DMARKET_OFFERS_PATH=/exchange/v1/offers-by-title
DMARKET_GAME_ID=a8db

# Отримати: https://dmarket.com/settings → Trading API → Generate Keys
# Public key — lowercase hex з префіксом 0x
DMARKET_PUBLIC_KEY=0x_your_public_key_here
DMARKET_SECRET_KEY=your_secret_key_here

# Скільки айтемів обробляти за один батч
DMARKET_OFFERS_BATCH_SIZE=50
# Максимум офферів на один скін
DMARKET_OFFERS_LIMIT=100
DMARKET_OFFERS_MAX_PAGES=50

# Затримка між запитами (мс) — не зменшуй нижче 100
DMARKET_OFFERS_REQUEST_DELAY_MS=200
DMARKET_OFFERS_HTTP_MAX_RETRIES=8
DMARKET_OFFERS_FETCH_TIMEOUT_MS=30000
DMARKET_OFFERS_MAX_WAIT_MS=15000

DMARKET_OFFERS_LOOP_SLEEP_MS=5000
DMARKET_OFFERS_RESET_SLEEP_MS=60000

# Шляхи до БД (відносно папки offers_parse/)
DMARKET_ITEMS_DMARKET_DB_PATH=../database/items_dmarket.db
DMARKET_OFFERS_DMARKET_DB_PATH=../database/offers_dmarket.db

# ── Whitemarket offers ─────────────────────────────────────────
# Отримати: https://white.market/profile/api → Partner Token
WHITE_ENDPOINT=https://api.white.market/graphql/partner
WHITE_PARTNER_TOKEN=your_white_partner_token_here
WHITE_APP_ID=CSGO

# Скільки айтемів обробляти за один батч
WHITE_OFFERS_BATCH_SIZE=500
WHITE_OFFERS_PAGE_SIZE=100
WHITE_OFFERS_MAX_PER_ITEM=500

# Кількість паралельних запитів (не більше 5 — інакше 429 Too Many Requests)
WHITE_OFFERS_CONCURRENCY=3
# Затримка між запитами (мс)
WHITE_OFFERS_REQUEST_DELAY_MS=150
WHITE_OFFERS_HTTP_MAX_RETRIES=6
WHITE_OFFERS_FETCH_TIMEOUT_MS=30000
WHITE_OFFERS_MAX_WAIT_MS=15000

WHITE_OFFERS_LOOP_SLEEP_MS=1000
WHITE_OFFERS_RESET_SLEEP_MS=60000

WHITEMARKET_ITEMS_WHITEMARKET_DB_PATH=../database/items_whitemarket.db
WHITE_OFFERS_WHITEMARKET_DB_PATH=../database/offers_whitemarket.db
